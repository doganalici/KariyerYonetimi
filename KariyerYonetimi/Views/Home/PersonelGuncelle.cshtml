@model KariyerYonetimi.Models.Personel

<h1>Personel Güncelle</h1>
<hr />

<form asp-controller="Home" asp-action="PersonelGuncelle" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group mb-3">
        <label asp-for="Ad"></label>
        <input asp-for="Ad" class="form-control" />
    </div>
    <div class="form-group  mb-3">
        <label asp-for="Soyad"></label>
        <input asp-for="Soyad" class="form-control" />
    </div>
    <div class="form-group  mb-3">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="form-group  mb-3">
        <label asp-for="Telefon"></label>
        <input asp-for="Telefon" class="form-control" />
    </div>
    <div class="form-group  mb-3">
        <label asp-for="Unvan"></label>
        <input asp-for="Unvan" class="form-control" />
    </div>
    <div class="form-group  mb-3">
        <label asp-for="Maas"></label>
        <input asp-for="Maas" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Personeli Kaydet</button>
</form>