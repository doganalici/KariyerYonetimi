@model List<KariyerYonetimi.Models.Personel>



<div class="container mt-4">
    <h1 class="text-light fw-bold mb-3">Şirket Personel Kadrosu</h1>

    <div class="d-flex justify-content-end mb-4">
        <a asp-controller="Home" asp-action="PersonelEkle" class="btn btn-primary btn-lg shadow-sm">+ Yeni Personel Ekle</a>
    </div>

    <hr class="text-secondary" />

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var personel in Model)
        {
            <div class="col">
                <div class="card h-100 shadow border-0 bg-dark text-light">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle bg-secondary p-3 me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="bi bi-person-fill fs-4 text-white">👤</i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0 fw-bold">@personel.Ad @personel.Soyad</h5>
                                <small class="text-info">@personel.Unvan</small>
                            </div>
                        </div>

                        <p class="card-text mb-1"><strong class="text-muted">E-Posta:</strong> @personel.Email</p>
                        <p class="card-text mb-1"><strong class="text-muted">Telefon:</strong> @personel.Telefon</p>
                        <p class="card-text"><strong class="text-muted">Maaş:</strong> <span class="text-success fw-bold">₺@personel.Maas.ToString("N2")</span></p>
                    </div>

                    <div class="card-footer bg-transparent border-top border-secondary d-flex justify-content-between">
                        <a asp-controller="Home" asp-action="PersonelDetay" asp-route-id="@personel.Id" class="btn btn-outline-info btn-sm">Detay Gör</a>
                        <div class="btn-group">
                            <a asp-controller="Home" asp-action="PersonelGuncelle" asp-route-id="@personel.Id" class="btn btn-warning btn-sm">Güncelle</a>
                            <a asp-controller="Home" asp-action="PersonelSil" asp-route-id="@personel.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bu personeli silmek istediğinize emin misiniz?')">Sil</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card mt-5 bg-secondary text-white shadow-sm border-0">
        <div class="card-body d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold">Aylık Toplam Maliyet :</h4>
            <h3 class="mb-0 fw-bold text-warning">₺@Model.Sum(p => p.Maas).ToString("N2")</h3>
        </div>
    </div>
</div>