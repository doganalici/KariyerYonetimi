@model KariyerYonetimi.Models.Personel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 bg-dark text-light text-center p-4">

                <div class="d-flex justify-content-center mt-3 mb-4">
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center shadow-sm" style="width: 120px; height: 120px;">
                        <span style="font-size: 4rem;">👤</span>
                    </div>
                </div>
                <h2 class="fw-bold text-white mb-1">@Model.Ad @Model.Soyad</h2>
                <br />
                <span class="badge bg-primary fs-6 px-3 py-2 mb-4">@Model.Departman?.Ad</span>

                <hr class="border-secondary my-3" />

                <div class="text-start px-3">
                    <div class="mb-3 d-flex align-items-center">
                        <strong class="text-white fw-bold w-25">Sistem ID:</strong>
                        <span class="text-warning fw-bold ms-2">#@Model.Id</span>
                    </div>
                    <div class="mb-3 d-flex align-items-center">
                        <strong class="text-white fw-bold w-25">E-Posta:</strong>
                        <span class="text-light ms-2">@Model.Email</span>
                    </div>
                    <div class="mb-3 d-flex align-items-center">
                        <strong class="text-white fw-bold w-25">Telefon:</strong>
                        <span class="text-light ms-2">@Model.Telefon</span>
                    </div>
                    <div class="mb-3 d-flex align-items-center">
                        <strong class="text-white fw-bold w-25">Maaş:</strong>
                        <span class="text-success fw-bold ms-2">₺@Model.Maas.ToString("N2")</span>
                    </div>
                </div>

                <hr class="border-secondary my-3" />
                <div class="card-body d-flex justify-content-between pt-2">
                    <a asp-action="Personeller" class="btn btn-outline-light px-4">🔙 Listeye Dön</a>
                    <div class="d-flex gap-2">
                        <a asp-action="PersonelGuncelle" asp-route-id="@Model.Id" class="btn btn-warning px-3">Düzenle</a>
                        <a href="#"
                           data-href="@Url.Action("PersonelSil", "Home", new { id = Model.Id })"
                           class="btn btn-danger px-3 sil-buton-tetikleyici"
                           data-bs-toggle="modal"
                           data-bs-target="#silmeOnayModal">Sil</a>
                    </div>
                </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Modalı -->
<div class="modal fade" id="silmeOnayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-light border-secondary shadow-lg">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title fw-bold text-danger">⚠️ Personel Silme Onayı</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-start py-3">
                <p class="mb-0">Bu personeli (<strong class="text-white">@Model.Ad @Model.Soyad</strong>) sistemden tamamen silmek istediğinize emin misiniz?</p>
                <small class="text-white-50">Bu işlem geri alınamaz ve tüm veriler kalıcı olarak temizlenir.</small>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-outline-light px-3" data-bs-dismiss="modal">İptal Et</button>
                <!-- Gerçek silme işlemini tetikleyecek buton -->
                <a id="modalSilButon" href="#" class="btn btn-danger px-4 shadow-sm">Evet, Sil</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const silButonlari = document.querySelectorAll('.sil-buton-tetikleyici');
            const modalSilButon = document.getElementById('modalSilButon');

            silButonlari.forEach(buton => {
                buton.addEventListener('click', function (e) {
                    e.preventDefault();
                    const silmeLinki = this.getAttribute('data-href');
                    modalSilButon.setAttribute('href', silmeLinki);
                });
            });
        });
    </script>
}