@model KariyerYonetimi.Models.Personel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 bg-dark text-light">
                <div class="card-header bg-transparent border-bottom border-secondary pt-4 pb-3 text-center">
                    <h3 class="fw-bold text-primary mb-0">✨ Yeni Personel Kaydı</h3>
                    <small class="text-muted">Sisteme yeni bir çalışan entegre edin</small>
                </div>

                <div class="card-body p-4">
                    <form asp-controller="Home" asp-action="PersonelEkle" method="post">

                        <div class="form-floating mb-3 text-dark">
                            <input asp-for="Ad" class="form-control bg-secondary text-white border-0" placeholder="Ad" required />
                            <label asp-for="Ad" class="text-light">Personel Adı</label>
                        </div>

                        <div class="form-floating mb-3 text-dark">
                            <input asp-for="Soyad" class="form-control bg-secondary text-white border-0" placeholder="Soyad" required />
                            <label asp-for="Soyad" class="text-light">Personel Soyadı</label>
                        </div>

                        <div class="form-floating mb-3 text-dark">
                            <input asp-for="Email" type="email" class="form-control bg-secondary text-white border-0" placeholder="name@example.com" required />
                            <label asp-for="Email" class="text-light">E-Posta Adresi</label>
                        </div>

                        <div class="form-floating mb-3 text-dark">
                            <input asp-for="Telefon" type="tel" class="form-control bg-secondary text-white border-0" placeholder="0555..."  required />
                            <label asp-for="Telefon" class="text-light">Telefon Numarası</label>
                            <span id="telefon-hata" class="text-danger small"></span>
                        </div>
                        <div class="form-floating mb-3 text-dark">
                            <input asp-for="Telefon2" type="tel" class="form-control bg-secondary text-white border-0" placeholder="0555..." />
                            <label asp-for="Telefon2" class="text-light">İkinci Telefon Numarası (Opsiyonel)</label>
                            <span id="telefon2-hata" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3 text-dark">
                            @* <input asp-for="Unvan" class="form-control bg-secondary text-white border-0" placeholder="Unvan" required /> *@
                            <select asp-for="DepartmanId" asp-items="@ViewBag.Departmanlar" class="form-select bg-dark text-light border-secondary" required>
                                <option value="">Lütfen Departman Seçiniz</option>   
                            </select>
                            <label asp-for="DepartmanId" class="text-light">Şirket İçi Unvanı</label>
                        </div>

                        <div class="form-floating mb-4 text-dark">
                            <input asp-for="Maas" type="number" class="form-control bg-secondary text-white border-0" placeholder="Maaş" required />
                            <label asp-for="Maas" class="text-light">Aylık Net Maaş (TL)</label>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Personeller" class="btn btn-outline-secondary me-md-2">İptal Et</a>
                            <button type="submit" class="btn btn-primary px-4 shadow">Personeli Sisteme Kaydet</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.inputmask/5.0.8/jquery.inputmask.min.js"></script>
    <script>
        $(document).ready(function(){
            // Maskeleri tanımla
            $('#Telefon').inputmask('0(999) 999 99 99');
            $('#Telefon2').inputmask('0(999) 999 99 99');

            // Form gönderilirken doğruluğu kontrol et
            $('form').on('submit', function(e) {
                var hataVar = false;

                // Temizleme: Önceki hataları sil
                $('#telefon-hata').text('');
                $('#telefon2-hata').text('');

                // 1. Telefon Kontrolü (Zorunlu ve Tam Olmalı)
                var tel1 = $('#Telefon').val();
                if (!tel1 || $('#Telefon').inputmask('isComplete') === false) {
                    $('#telefon-hata').text('Lütfen telefon numarasını eksiksiz giriniz.');
                    hataVar = true;
                }

                // 2. Telefon Kontrolü (Opsiyonel: Boşsa geç, doldurulduysa TAM olmak zorunda)
                var tel2 = $('#Telefon2').val();
                // Maske dolayısıyla sadece "0(   )    " gibi kalmışsa veya tamamen boşsa kontrol etme
                var sadeceMaskeMi = tel2.replace(/[^0-9]/g, '').length <= 1; // Sadece baştaki '0' kalmışsa

                if (!sadeceMaskeMi && $('#Telefon2').inputmask('isComplete') === false) {
                    $('#telefon2-hata').text('Lütfen ikinci telefon numarasını eksiksiz giriniz.');
                    hataVar = true;
                }

                // Eğer herhangi bir hata varsa formu göndermeyi engelle
                if (hataVar) {
                    e.preventDefault();
                }
            });
        });
    </script>
}